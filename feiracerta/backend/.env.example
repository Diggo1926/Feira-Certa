# Configurações do servidor
PORT=3000
NODE_ENV=production

# CORS - URL do frontend no Vercel
FRONTEND_URL=https://feira-certa.vercel.app/

# Banco de dados PostgreSQL
# No Railway essa variável é injetada automaticamente pelo plugin PostgreSQL — não precisa configurar manualmente.
# Para desenvolvimento local, crie um banco e preencha a URL abaixo.
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Web Push - gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=sua_chave_publica_vapid
VAPID_PRIVATE_KEY=sua_chave_privada_vapid
VAPID_EMAIL=mailto:seu@email.com
