# Configurações do servidor
PORT=3000
NODE_ENV=production

# CORS - URL do frontend no Vercel
FRONTEND_URL=https://seu-app.vercel.app

# Web Push - gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=sua_chave_publica_vapid
VAPID_PRIVATE_KEY=sua_chave_privada_vapid
VAPID_EMAIL=mailto:seu@email.com

# SQLite - caminho do banco (no Railway use /data/feiracerta.db para volume persistente)
DB_PATH=/data/feiracerta.db
